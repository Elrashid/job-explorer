{
  "manifest_version": 3,
  "name": "LinkedIn Job Saver",
  "version": "1.0",
  "description": "Save all open LinkedIn job tabs as HTML files",
  "permissions": ["tabs", "scripting", "downloads"],
  "host_permissions": ["*://*.linkedin.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png"
    }
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
